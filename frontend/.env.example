# Dev: leave empty to proxy /v1 through Vite (recommended for development)
# This avoids direct port connections and respects browser security policies
# In production: set to your API endpoint (e.g., https://api.example.com)
VITE_API_BASE_URL=

# Vite dev proxy target — set to match your backend API port and address
# Default is http://localhost:8080 (Node.js/Express backend)
# If your backend is on a different port, update this value
VITE_API_PROXY_TARGET=http://localhost:8080

# Laravel public storage for activity cover images
VITE_STORAGE_BASE_URL=http://localhost:8000/storage

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000
