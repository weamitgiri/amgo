# Dev: leave empty to proxy /v1 through Vite (recommended)
# Or set direct URL: http://localhost:6000
VITE_API_BASE_URL=

# Vite dev proxy target — must match apis/.env PORT
VITE_API_PROXY_TARGET=http://localhost:6000

# Laravel public storage for activity cover images
VITE_STORAGE_BASE_URL=http://localhost:8000/storage

VITE_API_TIMEOUT=30000
