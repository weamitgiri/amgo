# API base URL for frontend requests
VITE_API_BASE_URL=

# Node API port (must match apis/.env PORT). Used by Vite proxy only.
VITE_API_PROXY_TARGET=http://localhost:6001

# Socket.IO server URL
VITE_SOCKET_URL=http://localhost:6001

VITE_STORAGE_BASE_URL=http://localhost/p/public/storage
VITE_API_TIMEOUT=30000
